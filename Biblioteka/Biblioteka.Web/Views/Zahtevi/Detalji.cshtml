@model Biblioteka.DAL.Models.ZahtevZaPozajmljivanje
@{
    ViewData["Title"] = "Obrada zahteva";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white"><h5>Obrada zahteva</h5></div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Korisnik</dt>
                        <dd class="col-sm-8">@Model.Korisnik?.Email</dd>
                        <dt class="col-sm-4">Knjiga</dt>
                        <dd class="col-sm-8">@Model.Knjiga?.Naslov</dd>
                        <dt class="col-sm-4">Datum zahteva</dt>
                        <dd class="col-sm-8">@Model.DatumZahteva.ToString("dd.MM.yyyy HH:mm")</dd>
                        <dt class="col-sm-4">Trenutni status</dt>
                        <dd class="col-sm-8">@Model.Status</dd>
                    </dl>
                    <form asp-action="ObradiZahtev" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label">Napomena (opciono)</label>
                            <textarea name="napomena" class="form-control" rows="3">@Model.NapomenaAdmina</textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" name="akcija" value="odobri" class="btn btn-success">✅ Odobri</button>
                            <button type="submit" name="akcija" value="odbij" class="btn btn-danger">❌ Odbij</button>
                            <button type="submit" name="akcija" value="vrati" class="btn btn-secondary">📚 Vraćeno</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <a asp-action="Index" class="btn btn-link mt-3">← Nazad</a>
</div>