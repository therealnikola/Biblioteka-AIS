@model Biblioteka.Web.Models.RegistracijaViewModel
@{
    ViewData["Title"] = "Registracija";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header bg-success text-white text-center">
                    <h4>📝 Registracija</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Registracija" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Lozinka" class="form-label"></label>
                            <input asp-for="Lozinka" class="form-control" type="password" />
                            <span asp-validation-for="Lozinka" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="PotvrdaLozinke" class="form-label"></label>
                            <input asp-for="PotvrdaLozinke" class="form-control" type="password" />
                            <span asp-validation-for="PotvrdaLozinke" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-success w-100">Registruj se</button>
                    </form>
                </div>
                <div class="card-footer text-center">
                    Već imaš nalog? <a asp-action="Prijava">Prijavi se</a>
                </div>
            </div>
        </div>
    </div>
</div>