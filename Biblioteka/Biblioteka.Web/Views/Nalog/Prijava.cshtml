@model Biblioteka.Web.Models.PrijavaViewModel
@{
    ViewData["Title"] = "Prijava";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4>🔐 Prijava</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Prijava" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="email@primer.rs" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Lozinka" class="form-label"></label>
                            <input asp-for="Lozinka" class="form-control" type="password" />
                            <span asp-validation-for="Lozinka" class="text-danger"></span>
                        </div>
                        <div class="mb-3 form-check">
                            <input asp-for="ZapamtiMe" class="form-check-input" />
                            <label asp-for="ZapamtiMe" class="form-check-label"></label>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Prijavi se</button>
                    </form>
                </div>
                <div class="card-footer text-center">
                    Nemaš nalog? <a asp-action="Registracija">Registruj se</a>
                </div>
            </div>
        </div>
    </div>
</div>